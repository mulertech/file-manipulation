{
  "name": "mulertech/file-manipulation",
  "description": "This package manipulates and organizes files and path",
  "type": "library",
  "keywords": ["php", "file", "path", "filesystem"],
  "minimum-stability": "stable",
  "license": "MIT",
  "authors": [
    {
      "name": "Sébastien Muler",
      "email": "sebastien.muler@mulertech.net"
    }
  ],
  "require": {
    "php": "^8.3",
    "symfony/yaml": "^7"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.6",
    "mulertech/docker-dev": "^3.2",
    "phpstan/phpstan": "^2.1",
    "phpunit/phpunit": "^12",
    "roave/security-advisories": "dev-latest"
  },
  "autoload": {
    "psr-4": {
      "MulerTech\\FileManipulation\\": "./src"
    }
  },
  "autoload-dev": {
      "psr-4": {
      "MulerTech\\FileManipulation\\Tests\\": "./tests"
      }
  }
}